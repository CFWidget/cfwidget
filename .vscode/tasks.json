{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Database",
            "type": "docker-run",
            "dockerRun": {
                "image": "mariadb",
                "ports": [
                    {
                        "hostPort": 3306,
                        "containerPort": 3306
                    }
                ],
                "env": {
                    "MYSQL_USER": "widget",
                    "MYSQL_PASSWORD": "widget",
                    "MYSQL_DATABASE": "widget",
                    "MYSQL_RANDOM_ROOT_PASSWORD": "true"
                }
            }
        }
    ]
}